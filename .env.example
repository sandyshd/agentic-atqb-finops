FINOPS_ENV=demo
INGEST_INTERVAL_SECONDS=20
ENABLE_COST_SIGNAL_SIMULATION=false
ENABLE_MAG_SIMULATION=false
ENABLE_BROKER_BASELINE_QUOTES=false
LOW_RISK_CONFIDENCE_THRESHOLD=0.75
ACTION_MODE=guardrailed-auto
MAX_AUTO_MONTHLY_SAVINGS_USD=5000

# Azure adapter live ingestion settings
AZURE_ADAPTER_ENABLED=true
AZURE_SUBSCRIPTION_ID=
# AZURE_SUBSCRIPTION_IDS=sub-1,sub-2
AZURE_COST_LOOKBACK_HOURS=72
AZURE_ADAPTER_CACHE_SECONDS=1800
AZURE_ADAPTER_MIN_QUERY_INTERVAL_SECONDS=900
AZURE_ADAPTER_THROTTLE_BACKOFF_SECONDS=120
AZURE_ADAPTER_THROTTLE_MAX_BACKOFF_SECONDS=3600
AZURE_ADAPTER_MAX_SIGNALS=50

# Broker quote provider settings
BROKER_QUOTE_REFRESH_SECONDS=45
BROKER_AZURE_REGION=eastus
# AWS adapter settings (optional; requires boto3 and AWS credentials)
BROKER_AWS_REGION=
BROKER_AWS_INSTANCE_TYPE=g4dn.xlarge
# NeoCloud adapter settings (optional; requires external endpoint)
BROKER_NEOCLOUD_QUOTE_URL=
